# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/multi_ai_studio"

# Redis
REDIS_URL="redis://localhost:6380"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="multi-ai-studio"
MINIO_USE_SSL="false"

# Google Auth (NextAuth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV=development

# Gemini
GEMINI_API_KEY=""

# API
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
PORT=4000
# Shared secret between Next.js and NestJS API — generate with: openssl rand -hex 32
API_SECRET=""
