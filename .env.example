# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/multi_ai_studio"

# Redis
REDIS_URL="redis://localhost:6380"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="multi-ai-studio"
MINIO_USE_SSL="false"

# Google Auth (NextAuth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV=development

# Gemini
GEMINI_API_KEY=""

# API
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
PORT=4000
# Shared secret between Next.js and NestJS API — generate with: openssl rand -hex 32
API_SECRET=""

# Google Drive
GOOGLE_SERVICE_ACCOUNT_EMAIL="botcriador@sqddgtl.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_KEY="<your-service-account-private-key>"
GOOGLE_DRIVE_ROOT_FOLDER_ID="16X3WZRaYQndX18rBN-xFplrmFg-W6LN9"

# Drive Sync
DRIVE_SYNC_CRON="0 3 * * *"
DRIVE_SYNC_MATCH_THRESHOLD=0.75

# Embeddings
EMBEDDING_MODEL="gemini-embedding-2-preview"
EMBEDDING_DIMENSIONS=256

# Art Composition
ART_MODEL="gemini-3.1-flash-image-preview"
ART_DEFAULT_RESOLUTION="2K"
